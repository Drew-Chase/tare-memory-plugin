<idea-plugin>
    <id>dev.tare.plugin</id>
    <name>Tare</name>
    <vendor>tare</vendor>
    <description><![CDATA[
        Inline Rust memory allocation viewer. Annotates source lines with
        heap allocation data from runtime profiling and static analysis.
        <br/><br/>
        <b>Automatic:</b> Static analysis runs on project open, flagging
        allocation sites (Box::new, Vec::with_capacity, .collect(), etc.)
        with no setup required.
        <br/><br/>
        <b>One-click profiling:</b> Use Tools > Run Tare Analysis to
        capture real heap bytes via dhat and merge with static data.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Project service: loads and caches allocation data -->
        <projectService
            serviceImplementation="dev.tare.plugin.TareDataService"/>

        <!-- Settings -->
        <projectConfigurable
            parentId="tools"
            instance="dev.tare.plugin.TareSettingsConfigurable"
            id="dev.tare.plugin.settings"
            displayName="Tare Allocation Viewer"/>

        <!-- Auto-run static analysis on project open -->
        <postStartupActivity
            implementation="dev.tare.plugin.TareStartupActivity"/>

        <!-- Notification group for analysis progress/results -->
        <notificationGroup
            id="Tare"
            displayType="BALLOON"
            isLogByDefault="true"/>

        <!-- Declarative inlay hints (language-agnostic; filtering in createCollector) -->
        <codeInsight.declarativeInlayProvider
            implementationClass="dev.tare.plugin.TareInlayHintsProvider"
            isEnabledByDefault="true"
            providerId="tare.allocation.hints"
            language=""
            bundle="messages.TareBundle"
            nameKey="tare.inlay.provider.name"
            group="OTHER_GROUP"/>

        <!-- Gutter line markers -->
        <codeInsight.lineMarkerProvider
            language=""
            implementationClass="dev.tare.plugin.TareLineMarkerProvider"/>

        <!-- Run configuration: full-control profiling -->
        <configurationType
            implementation="dev.tare.plugin.TareRunConfigurationType"/>
    </extensions>

    <actions>
        <action id="Tare.Analyze"
                class="dev.tare.plugin.TareAnalyzeAction"
                text="Run Tare Analysis"
                description="Analyze allocation sites and/or profile heap usage"
                icon="AllIcons.Actions.ProfileCPU">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
